{
  "name": "nine-gates-mahjong",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run typecheck:worker && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
    "test:games": "tsx scripts/game-completion-smoke.mjs",
    "test:ui": "node scripts/game-ui-smoke.mjs",
    "test:controls": "tsx scripts/game-controls-smoke.mjs",
    "test:features": "node scripts/feature-smoke.mjs",
    "test:variants": "node scripts/variant-ui-smoke.mjs",
    "test:site": "node scripts/site-smoke.mjs",
    "test:production": "node scripts/production-smoke.mjs",
    "test:multiplayer": "node scripts/multiplayer-smoke.mjs",
    "test:multiplayer-ui": "node scripts/multiplayer-ui-smoke.mjs",
    "test:auth": "node scripts/auth-smoke.mjs",
    "test:release": "npm run test:games && npm run test:ui && npm run test:controls && npm run test:variants && npm run test:features && npm run test:site && npm run test:auth && npm run test:multiplayer && npm run test:multiplayer-ui",
    "worker:dev": "wrangler dev src/worker/entry.ts",
    "worker:deploy": "wrangler deploy src/worker/entry.ts",
    "db:migrate": "wrangler d1 execute DB --file=src/worker/db/migrations/0001_initial.sql"
  },
  "dependencies": {
    "framer-motion": "^12.0.0",
    "phaser": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
