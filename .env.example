# ===================================================
# Nine Gates Mahjong - Environment Variables
# Copy to .env and fill in your values
# ===================================================

# App
VITE_APP_NAME=Nine Gates Mahjong
VITE_SITE_DOMAIN=https://ninegatesmahjong.com
VITE_API_BASE_URL=/api

# Adsterra Integration
# Each High Performance Format placement has its own size-specific key.
# Leave a value blank to keep the built-in house-ad fallback for that placement.
VITE_ADSTERRA_320X50_KEY=
VITE_ADSTERRA_728X90_KEY=
VITE_ADSTERRA_160X600_KEY=

# Optional Social Bar script URL supplied by Adsterra. It loads only after consent.
VITE_ADSTERRA_SOCIAL_BAR_URL=
