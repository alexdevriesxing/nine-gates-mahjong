# ===================================================
# Nine Gates Mahjong - Environment Variables
# Copy to .env and fill in your values
# ===================================================

# App
VITE_APP_NAME=Nine Gates Mahjong
VITE_SITE_DOMAIN=https://ninegatesmahjong.com
VITE_API_BASE_URL=/api

# Feature Flags
VITE_ENABLE_AD_PLACEHOLDERS=true
VITE_ENABLE_MULTIPLAYER=false
VITE_ENABLE_MOCK_AUTH=true

# Adsterra Integration (replace with your live keys for production)
VITE_ADSTERRA_BANNER_KEY=placeholder_banner_key
VITE_ADSTERRA_NATIVE_KEY=placeholder_native_key
VITE_ADSTERRA_SOCIAL_BAR_KEY=placeholder_social_bar_key
VITE_ADSTERRA_INTERSTITIAL_KEY=placeholder_interstitial_key
VITE_ADSTERRA_SMARTLINK_URL=https://example.com/smartlink
