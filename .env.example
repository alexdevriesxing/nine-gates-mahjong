# ===================================================
# Nine Gates Mahjong - Environment Variables
# Copy to .env and fill in deployment-specific values
# ===================================================

# App
VITE_APP_NAME=Nine Gates Mahjong
VITE_SITE_DOMAIN=https://ninegatesmahjong.com
VITE_API_BASE_URL=/api

# Advertising
# Third-party placements are rendered only after explicit user consent.
# Approved banner and native placement IDs live in src/shared/ads.ts so the
# browser and Cloudflare Worker validate the same inventory.

# Optional Social Bar script URL supplied by the advertising provider.
# The script is never injected before the visitor accepts advertising.
VITE_ADSTERRA_SOCIAL_BAR_URL=
